# WhatsApp number (without + sign, with country code)
# Example: 919876543210
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Business Name
NEXT_PUBLIC_BUSINESS_NAME="Your Business Name"

# Domain
NEXT_PUBLIC_DOMAIN="yourdomain.in"

# Delivery Fee
# Set to "true" to enable delivery fee, "false" to disable
NEXT_PUBLIC_DELIVERY_FEE_ENABLED=true
# Delivery fee amount in rupees (0 = Free Delivery)
NEXT_PUBLIC_DELIVERY_FEE_PRICE=30
